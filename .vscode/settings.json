{
    "explorer.excludeGitIgnore": false,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.papyrus": true,
        "**/.ruff_cache": true,
        "**/.claude": true
    },
    "files.watcherExclude": {
        "**/output/**": true,
        "**/export/**": true,
        "**/temp/**": true,
        "**/references/**": true,
    },
    "diffEditor.diffAlgorithm": "legacy",
}
